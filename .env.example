# FreePBX API
FREEPBX_HOST=pbx.example.com
FREEPBX_PORT=2443
FREEPBX_API_BASE_PATH=/admin/api/api
FREEPBX_VERIFY_SSL=true
FREEPBX_TIMEOUT=30

# Authentication — provide OAuth2 credentials OR a static API token
FREEPBX_CLIENT_ID=
FREEPBX_CLIENT_SECRET=
FREEPBX_API_TOKEN=

# Asterisk AMI (optional — enables live stats and admin actions)
AMI_HOST=pbx.example.com
AMI_PORT=5038
AMI_USERNAME=admin
AMI_SECRET=your-ami-secret-here
AMI_TIMEOUT=10

# Database (optional — only if direct DB access is needed)
# DB_HOST=pbx.example.com
# DB_PORT=3306
# DB_NAME=asterisk
# DB_USER=freepbx
# DB_PASSWORD=your-db-password-here

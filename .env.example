# FreePBX GraphQL API
FREEPBX_HOST=
FREEPBX_API_TOKEN=your-api-token-here
FREEPBX_PORT=443
FREEPBX_VERIFY_SSL=true
FREEPBX_TIMEOUT=30

# Asterisk AMI (optional — enables live stats and admin actions)
AMI_HOST=pbx.example.com
AMI_PORT=5038
AMI_USERNAME=admin
AMI_SECRET=your-ami-secret-here
AMI_TIMEOUT=10

# Database (optional — only if direct DB access is needed)
# DB_HOST=pbx.example.com
# DB_PORT=3306
# DB_NAME=asterisk
# DB_USER=freepbx
# DB_PASSWORD=your-db-password-here
